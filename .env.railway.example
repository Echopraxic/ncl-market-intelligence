# ─── API service (set in Railway dashboard → ncl-api → Variables) ───────────

# Provided automatically by Railway when you add a Postgres plugin
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DB

# Provided automatically by Railway when you add a Redis plugin
# BullMQ requires Redis >= 5 — Railway Redis 7 satisfies this, resolving the
# Windows dev blocker (local Redis 3.0.504).
REDIS_URL=redis://HOST:PORT

# Choose a long random string — used by the dashboard to authenticate API calls
API_SECRET_KEY=change-me-32-chars-minimum

# DeepSeek LLM — copy from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Resend — copy from https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...

# "From" address for outreach emails (must be a verified Resend domain)
EMAIL_FROM=outreach@yourdomain.com

# Public URL of the deployed dashboard (used in email templates)
DASHBOARD_URL=https://ncl-dashboard.up.railway.app

NODE_ENV=production
PORT=3001

# ─── Dashboard service (set in Railway dashboard → ncl-dashboard → Variables) ─

# Internal Railway private network URL of the API service, or the public URL
API_URL=https://ncl-api.up.railway.app
API_SECRET_KEY=change-me-32-chars-minimum   # same value as above

NODE_ENV=production
PORT=3000
