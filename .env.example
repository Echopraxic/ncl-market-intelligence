# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://ncl_user:ncl_password@localhost:5432/ncl_mie

# ─── Cache / Queue ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Data Sources ───────────────────────────────────────────
SERPAPI_KEY=

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@northchannellogistics.com

# ─── API Auth ───────────────────────────────────────────────
API_SECRET_KEY=change-me-in-production

# ─── App Config ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3001

# ─── Crawler Config ─────────────────────────────────────────
CRAWLER_RATE_LIMIT_MS=2000

# ─── Scoring / Scheduling ───────────────────────────────────
SCORING_CRON=0 2 * * *
MAX_OUTREACH_PER_DAY=50

# ─── Dashboard ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
