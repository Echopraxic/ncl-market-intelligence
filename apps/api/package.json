{
  "name": "@ncl/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@fastify/cors": "^10.0.1",
    "bullmq": "^5.34.8",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "ioredis": "^5.3.2",
    "jstat": "^1.9.6",
    "p-limit": "^7.3.0",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^4.1.2",
    "simple-statistics": "^7.8.9",
    "svix": "^1.92.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
